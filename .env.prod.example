# ── Production env for Dokploy ──────────────────────────────────────
# Copy all variables below into Dokploy → Your App → Environment Variables.
# Never commit the filled-in version to git. Values marked REQUIRED must
# be filled before the first deploy.

# Public host (no scheme, no trailing slash) — used by Traefik routing
# labels in docker-compose.prod.yml.
PUBLIC_HOST=pavutyna.app

# ── Security (REQUIRED) ─────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be >= 32 chars. Backend refuses to boot with the default in prod.
JWT_SECRET=REPLACE_ME_WITH_RANDOM_SECRET

# ── Unipile (REQUIRED) ──────────────────────────────────────────────

# From Unipile dashboard → Access Tokens → the token you generated
UNIPILE_API_KEY=
# Your dedicated Unipile DSN, e.g. api38.unipile.com:16889
UNIPILE_DSN=
# Generate with the same command as JWT_SECRET. Must also be added on
# Unipile's dashboard → Webhooks → your webhook → Signing Secret.
UNIPILE_WEBHOOK_SECRET=

# ── AI (optional but recommended) ───────────────────────────────────

# https://console.anthropic.com → API Keys. Backend starts without it,
# AI features return 400 until this is set.
ANTHROPIC_API_KEY=

# ── Telegram API (optional — only for legacy direct Telethon) ───────
# Leave empty unless you explicitly need a fallback path. Unipile is the
# primary Telegram integration now.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# ── Stripe (Phase 4, leave empty for now) ───────────────────────────
STRIPE_SECRET_KEY=

# ── Mongo / Redis (managed by compose, do NOT change) ───────────────
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=pavutyna
REDIS_URL=redis://redis:6379/0
